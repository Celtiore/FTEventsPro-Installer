rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fichiers d'une organisation — isolation par orgId (custom claim)
    // Path: organizations/{orgId}/{collection}/{entityId}/{type}.jpg
    match /organizations/{orgId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.orgId == orgId;
    }

    // Bloquer tout acces hors du prefix organizations/
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
